const int b_wet_width  = 60;
const int b_wet_height = 60;




#include <Adafruit_GFX.h>
#include <Adafruit_ST7735.h>
#include <DHT.h>
#include <Adafruit_NeoPixel.h>

// ---------------- Pins & Constants ----------------
#define BTN_UP 17
#define BTN_DOWN 15

#define DHT_PIN 14
#define DHT_TYPE DHT11
#define THERM_PIN 26      
#define AMT_HUM_PIN 28    
#define AMT_TEMP_PIN 27   

// TFT Display Pins
#define TFT_SCL 6 // SCK
#define TFT_SDA 7 // MOSI
#define TFT_RST 8
#define TFT_DC  9
#define TFT_CS  10
#define TFT_BLK 11

#define NEO_PIN 23
#define NUM_PIXELS 1 

// ---------------- Image Arrays (Placeholders) ----------------
// REPLACE THESE `{0}` WITH THE OUTPUT FROM IMAGE2CPP
const uint16_t sprite_normal[3600] PROGMEM = {0};
const uint16_t sprite_sleep[3600] PROGMEM  = {0};
const uint16_t sprite_wet[3600] PROGMEM    = {0};
const uint16_t sprite_dry[3600] PROGMEM    = {0};
const uint16_t sprite_hot[3600] PROGMEM    = {0};
const uint16_t sprite_cold[3600] PROGMEM   = {0};

// ---------------- Objects ----------------
// Using Software SPI - Guaranteed to fix the White Screen bug on Mbed!
Adafruit_ST7735 tft = Adafruit_ST7735(TFT_CS, TFT_DC, TFT_SDA, TFT_SCL, TFT_RST);

DHT dht(DHT_PIN, DHT_TYPE);
Adafruit_NeoPixel strip(NUM_PIXELS, NEO_PIN, NEO_GRB + NEO_KHZ800);

// ---------------- State Variables ----------------
enum Mood { NORMAL, SLEEP, WET, DRY, HOT, COLD };
Mood currentMood = NORMAL;
Mood lastMood = NORMAL;

bool isSleeping = false;
bool forceDraw = true;
unsigned long lastUpdate = 0;

float airTemp = 0.0, airHum = 0.0;
float waterTemp = 0.0;
float outHum = 0.0;

// ---------------- Setup ----------------
void setup() {
  Serial.begin(115200);

  pinMode(BTN_UP, INPUT_PULLUP);
  pinMode(BTN_DOWN, INPUT_PULLUP);
  pinMode(TFT_BLK, OUTPUT);
  digitalWrite(TFT_BLK, HIGH); // Turn on screen backlight

  // Initialize TFT
  tft.initR(INITR_BLACKTAB); // Try INITR_GREENTAB if colors look weird
  tft.setRotation(1);        // Landscape
  tft.fillScreen(ST77XX_BLACK);

  // Initialize Sensors
  dht.begin();
  strip.begin();
  strip.setBrightness(50);
  strip.show();
  
  // Set ADC to 12-bit (0-4095) for better Mbed RP2040 precision
  analogReadResolution(12);

  // Draw UI Borders just once
  tft.drawRect(8, 32, 64, 64, ST77XX_CYAN); // Border for the 60x60 Sprite
}

// ---------------- Main Loop ----------------
void loop() {
  // Check Sleep Button
  if (digitalRead(BTN_DOWN) == LOW) {
    isSleeping = !isSleeping;
    forceDraw = true;
    delay(300); // Debounce
  }

  // Update sensors every 2 seconds
  if (millis() - lastUpdate > 2000 || forceDraw) {
    lastUpdate = millis();
    readSensors();
    determineMood();
    updateUI();
    forceDraw = false;
  }
}

// ---------------- Functions ----------------

void readSensors() {
  // 1. Read DHT11
  float t = dht.readTemperature();
  float h = dht.readHumidity();
  if (!isnan(t)) airTemp = t;
  if (!isnan(h)) airHum = h;

  // 2. Read Thermistor
  int adcWater = analogRead(THERM_PIN);
  if (adcWater > 0 && adcWater < 4095) {
    float rTherm = (40950000.0 / adcWater) - 10000.0;
    float steinhart = log(rTherm / 10000.0) / 3950.0;                   
    steinhart += 1.0 / (25.0 + 273.15);     
    waterTemp = (1.0 / steinhart) - 273.15; 
  }

  // 3. Read AMT1001 (Humidity portion)
  int adcHum = analogRead(AMT_HUM_PIN);
  outHum = (adcHum / 4095.0) * 100.0; 
}

void determineMood() {
  if (isSleeping) {
    currentMood = SLEEP;
  } 
  // Prioritize extreme temperatures first
  else if (airTemp > 30.0 || waterTemp > 30.0) {
    currentMood = HOT;
  } 
  else if (airTemp < 15.0 || waterTemp < 15.0) {
    currentMood = COLD;
  } 
  // Then check for extreme humidity/moisture
  else if (airHum > 75.0 || outHum > 75.0) {
    currentMood = WET;
  } 
  else if (airHum < 30.0 || outHum < 30.0) {
    currentMood = DRY;
  } 
  // If all is good, it's normal!
  else {
    currentMood = NORMAL;
  }
}

void updateUI() {
  // 1. Update the Screen only if the mood changed (or on startup)
  if (currentMood != lastMood || forceDraw) {
    
    // Draw the corresponding array instantly based on the mood
    switch(currentMood) {
      case NORMAL: 
        strip.fill(strip.Color(0, 255, 0)); // Green
        tft.drawRGBBitmap(10, 34, sprite_normal, 60, 60);
        break;
        
      case SLEEP: 
        strip.fill(strip.Color(10, 10, 50)); // Dim Blue
        tft.drawRGBBitmap(10, 34, sprite_sleep, 60, 60);
        break;
        
      case WET: 
        strip.fill(strip.Color(0, 255, 200)); // Cyan / Wet
        tft.drawRGBBitmap(10, 34, sprite_wet, 60, 60);
        break;

      case DRY: 
        strip.fill(strip.Color(255, 200, 0)); // Yellow/Brown / Dry
        tft.drawRGBBitmap(10, 34, sprite_dry, 60, 60);
        break;
        
      case HOT: 
        strip.fill(strip.Color(255, 50, 0)); // Orange/Red
        tft.drawRGBBitmap(10, 34, sprite_hot, 60, 60);
        break;
        
      case COLD: 
        strip.fill(strip.Color(100, 150, 255)); // Bright Icy Blue
        tft.drawRGBBitmap(10, 34, sprite_cold, 60, 60);
        break;
    }
    strip.show();
    lastMood = currentMood;
  }

  // 2. Draw Text Data (this updates every 2 seconds)
  tft.setCursor(85, 20);
  tft.setTextColor(ST77XX_CYAN, ST77XX_BLACK);
  tft.print("Bamboo Care");
  
  tft.setTextColor(ST77XX_WHITE, ST77XX_BLACK);
  
  tft.setCursor(85, 45); 
  tft.print("AirT: "); tft.print(airTemp, 1); tft.print("C  ");
  
  tft.setCursor(85, 60); 
  tft.print("AirH: "); tft.print(airHum, 1); tft.print("%  ");
  
  tft.setCursor(85, 75); 
  tft.print("WatT: "); tft.print(waterTemp, 1); tft.print("C  ");
  
  tft.setCursor(85, 90); 
  tft.print("OutH: "); tft.print(outHum, 1); tft.print("%  ");
}